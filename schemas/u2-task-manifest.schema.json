{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://treexchange.local/schemas/u2-task-manifest.schema.json",
  "title": "treeXchange U2 user-directed task manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "queue_id", "repository", "origin", "item"],
  "properties": {
    "schema_version": { "const": 1 },
    "queue_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{7,95}$" },
    "repository": {
      "enum": ["leeshsnu/treeXchange-agent-executor", "leeshsnu/treeXchange-season2"]
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind", "directive_id", "requested_assignee", "intent",
        "instruction_digest", "recorded_at"
      ],
      "properties": {
        "kind": {
          "enum": ["user_directive", "ratified_plan", "review_followup", "agent_discovered", "gate_decision"]
        },
        "directive_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{7,95}$" },
        "requested_assignee": { "const": "Claude" },
        "intent": { "enum": ["review", "design_review", "build", "advice"] },
        "instruction_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "recorded_at": { "type": "string", "format": "date-time" }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_item_id", "depends_on", "role", "branch", "base_sha", "target_sha",
        "task_profile", "objective", "acceptance_criteria", "read_paths",
        "allowed_paths", "maximum_turns", "maximum_attempts", "window_id"
      ],
      "properties": {
        "work_item_id": { "type": "string", "pattern": "^[A-Z][A-Z0-9-]{1,31}$" },
        "depends_on": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "role": { "enum": ["repository_reviewer", "scoped_maker"] },
        "branch": { "type": "string", "minLength": 1 },
        "base_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "target_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "task_profile": { "enum": ["standard", "design", "advanced", "insight"] },
        "objective": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "acceptance_criteria": {
          "type": "array", "minItems": 1, "maxItems": 12,
          "uniqueItems": true, "items": { "type": "string", "minLength": 1 }
        },
        "read_paths": {
          "type": "array", "maxItems": 24,
          "uniqueItems": true, "items": { "type": "string", "minLength": 1 }
        },
        "allowed_paths": {
          "type": "array", "minItems": 1, "maxItems": 16,
          "uniqueItems": true, "items": { "type": "string", "minLength": 1 }
        },
        "maximum_turns": { "type": "integer", "minimum": 1, "maximum": 8 },
        "maximum_attempts": { "const": 1 },
        "window_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{7,63}$" }
      }
    }
  }
}
